# Google OAuth2 Client ID
# Hämtas från Google Cloud Console → APIs & Services → Credentials
# Se GOOGLE_SETUP.md för fullständiga instruktioner
VITE_GOOGLE_CLIENT_ID=your_client_id_here

# (Valfritt) ID för bandets delade Google-kalender
# Lämna tomt för att använda den inloggade användarens primärkalender
VITE_GOOGLE_CALENDAR_ID=
