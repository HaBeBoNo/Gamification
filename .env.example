# Google OAuth2 Client ID
# Hämtas från Google Cloud Console → APIs & Services → Credentials
# Se GOOGLE_SETUP.md för fullständiga instruktioner
VITE_GOOGLE_CLIENT_ID=your_client_id_here

# (Valfritt) ID för bandets delade Google-kalender
# Lämna tomt för att använda den inloggade användarens primärkalender
VITE_GOOGLE_CALENDAR_ID=

# (Valfritt) ID för bandets delade Drive-mapp
# Lämna tomt för att använda standardmappen i appen
VITE_GOOGLE_DRIVE_FOLDER_ID=

# Anthropic API-nyckel — används av serverless functions (INTE VITE_-prefix!)
# Hämtas från console.anthropic.com → API Keys
# OBS: Lägg till i Vercel Environment Variables, ej i klienten
ANTHROPIC_API_KEY=sk-ant-...
